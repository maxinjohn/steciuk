APP_NAME="STECI UK Parish"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
EXPOSE_EXCEPTION_DETAILS=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_VERSION=latest

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# =============================================================================
# Site data paths — point uploads & SQLite outside the app directory if needed
# =============================================================================
# Root storage directory (logs, cache, sessions, framework files)
# APP_STORAGE_PATH=/var/lib/steciuk/storage

# Public uploads served via /storage URL (defaults to {APP_STORAGE_PATH}/app/public)
# PUBLIC_STORAGE_PATH=/var/lib/steciuk/uploads
# PUBLIC_STORAGE_URL=/storage

# Private uploads (Filament media, documents)
# PRIVATE_STORAGE_PATH=/var/lib/steciuk/private

# =============================================================================
# Database (SQLite — absolute path recommended in production)
# =============================================================================
DB_CONNECTION=sqlite
# Local project: database/database.sqlite
# Docker default: /var/www/html/storage/database/database.sqlite
# Custom data dir: /var/lib/steciuk/storage/database/database.sqlite
DB_DATABASE=/var/www/html/storage/database/database.sqlite
DB_BUSY_TIMEOUT=5000
DB_JOURNAL_MODE=wal
DB_SYNCHRONOUS=normal

# =============================================================================
# Session & cache
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@steciuk.org"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Security
# =============================================================================
FORCE_HTTPS=false
CSP_ENABLED=true
BLOCK_SUSPICIOUS_REQUESTS=true
ADMIN_SESSION_LIFETIME=120
REQUIRE_MFA_SUPER_ADMIN=false
SECURITY_CONTACT=admin@steciuk.org
MAX_LOGIN_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15
LOG_EXCEPTION_MESSAGES=false

# Admin notification email for form submissions
ADMIN_EMAIL=admin@steciuk.org

# Trusted proxy (comma-separated IPs, or * behind load balancer)
TRUSTED_PROXIES=*

# =============================================================================
# Reference data seeding (industry-standard idempotent sync)
# =============================================================================
# off        — never seed automatically (default production)
# bootstrap  — first install: create all reference pages, menus, settings
# sync       — deploy: upsert seeded records by slug/key; keep prod-only data
SEED_MODE=off

# Only overwrite these on sync when you intentionally push dev changes:
SEED_OVERWRITE_SETTINGS=false
SEED_OVERWRITE_USER_PASSWORDS=false
SEED_OVERWRITE_PAGES=true

# =============================================================================
# Docker — ports and host data mounts
# =============================================================================
COMPOSE_PROJECT_NAME=steciuk

# Public website (nginx HTTP)
NGINX_HTTP_PORT=8080

# Public website (nginx HTTPS — enable when SSL certs mounted)
NGINX_HTTPS_PORT=8443

# Vite dev server (docker compose --profile dev only)
VITE_DEV_PORT=5173

# PHP-FPM (internal — exposed only if debugging)
PHP_FPM_PORT=9000

# Optional: expose app directly without nginx (not recommended for prod)
APP_DIRECT_PORT=8000

# Host paths for persistent data (absolute path = bind mount; unset = named volume)
# STORAGE_HOST_PATH=/var/lib/steciuk/storage
# BOOTSTRAP_CACHE_HOST_PATH=/var/lib/steciuk/bootstrap-cache

# Docker startup behaviour
RUN_MIGRATIONS=true
RUN_SEED=false
