APP_NAME="STECI UK Parish"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
EXPOSE_EXCEPTION_DETAILS=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_VERSION=latest

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# =============================================================================
# Database (SQLite — path inside container or local install)
# =============================================================================
DB_CONNECTION=sqlite
# Local: absolute path on host
# DB_DATABASE=/absolute/path/to/storage/database/database.sqlite
# Docker: use container path (set automatically in docker-compose.yml)
DB_DATABASE=/var/www/html/storage/database/database.sqlite

# =============================================================================
# Session & cache
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@steciuk.org"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Security
# =============================================================================
FORCE_HTTPS=false
CSP_ENABLED=true
BLOCK_SUSPICIOUS_REQUESTS=true
ADMIN_SESSION_LIFETIME=120
REQUIRE_MFA_SUPER_ADMIN=false
SECURITY_CONTACT=admin@steciuk.org

# Admin notification email for form submissions
ADMIN_EMAIL=admin@steciuk.org

# =============================================================================
# Docker — all ports customisable (host:container)
# =============================================================================
COMPOSE_PROJECT_NAME=steciuk

# Public website (nginx HTTP)
NGINX_HTTP_PORT=8080

# Public website (nginx HTTPS — enable when SSL certs mounted)
NGINX_HTTPS_PORT=8443

# Vite dev server (docker compose --profile dev only)
VITE_DEV_PORT=5173

# PHP-FPM (internal — exposed only if debugging)
PHP_FPM_PORT=9000

# Optional: expose app directly without nginx (not recommended for prod)
APP_DIRECT_PORT=8000

# Docker startup behaviour
RUN_MIGRATIONS=true
RUN_SEED=false

# Trusted proxy (set to * behind load balancer / nginx)
TRUSTED_PROXIES=*
