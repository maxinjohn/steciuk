# =============================================================================
# STECI UK Parish — Environment configuration
# Copy to .env and adjust for your environment:
#   cp .env.example .env && php artisan key:generate
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="STECI UK Parish"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
EXPOSE_EXCEPTION_DETAILS=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_VERSION=latest

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_EXCEPTION_MESSAGES=false

# -----------------------------------------------------------------------------
# Site data paths (optional — defaults to Laravel storage/)
# -----------------------------------------------------------------------------
# Move all runtime data outside the app directory on servers:
# APP_STORAGE_PATH=/var/lib/steciuk/storage

# Public uploads (served at APP_URL + PUBLIC_STORAGE_URL)
# PUBLIC_STORAGE_PATH=/var/lib/steciuk/uploads
PUBLIC_STORAGE_URL=/storage

# Private uploads (Filament media, documents)
# PRIVATE_STORAGE_PATH=/var/lib/steciuk/private

# -----------------------------------------------------------------------------
# Database (SQLite)
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite

# Local (no Docker): relative to project root
DB_DATABASE=storage/database/database.sqlite

# Docker: set in docker-compose or override here
# DB_DATABASE=/var/www/html/storage/database/database.sqlite

# Production custom data disk:
# DB_DATABASE=/var/lib/steciuk/storage/database/database.sqlite

DB_BUSY_TIMEOUT=5000
DB_JOURNAL_MODE=wal
DB_SYNCHRONOUS=normal
DB_FOREIGN_KEYS=true

# -----------------------------------------------------------------------------
# Session, cache & queue
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=file

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
# Local: use "log" — messages written to storage/logs/laravel.log
# Production: use "smtp" and set host/credentials below
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@steciuk.org"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
FORCE_HTTPS=false
CSP_ENABLED=true
BLOCK_SUSPICIOUS_REQUESTS=true
ADMIN_SESSION_LIFETIME=120
REQUIRE_MFA_SUPER_ADMIN=false
SECURITY_CONTACT=admin@steciuk.org
MAX_LOGIN_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15

# Form submission notifications (contact, prayer request, etc.)
ADMIN_EMAIL=admin@steciuk.org

# Comma-separated proxy IPs, or * behind nginx/load balancer
TRUSTED_PROXIES=

# -----------------------------------------------------------------------------
# Reference data seeding
# -----------------------------------------------------------------------------
# off       — no automatic seeding (use for production after bootstrap)
# bootstrap — first install: pages, menus, settings, sample content
# sync      — deploy: upsert seeded records; preserve prod-only data
SEED_MODE=bootstrap

# Only enable when intentionally pushing dev changes to production:
SEED_OVERWRITE_SETTINGS=false
SEED_OVERWRITE_USER_PASSWORDS=false
SEED_OVERWRITE_PAGES=true

# -----------------------------------------------------------------------------
# Docker — single container (nginx + PHP + queue + scheduler)
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=steciuk

# Host port mapped to container port 80
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# Processes inside the one container (supervisord)
RUN_QUEUE_WORKER=true
RUN_SCHEDULER=true

# Bind mounts (absolute host path). Leave commented to use named volumes.
# STORAGE_HOST_PATH=/var/lib/steciuk/storage
# BOOTSTRAP_CACHE_HOST_PATH=/var/lib/steciuk/bootstrap-cache

RUN_MIGRATIONS=true
RUN_SEED=false

# Note: Node/npm is NOT in the runtime container — only used at `docker build`
# to compile Vite/Tailwind assets into public/build/. For local CSS/JS changes
# without rebuilding the image, run `npm run dev` or `npm run build` on your host.

# -----------------------------------------------------------------------------
# Production overrides (uncomment and use on steciuk.org)
# -----------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://steciuk.org
# LOG_LEVEL=warning
# MAIL_MAILER=smtp
# FORCE_HTTPS=true
# REQUIRE_MFA_SUPER_ADMIN=true
# SEED_MODE=off
# TRUSTED_PROXIES=*

# -----------------------------------------------------------------------------
# Optional: AWS / Redis (not required for default SQLite setup)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-2
# AWS_BUCKET=
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
