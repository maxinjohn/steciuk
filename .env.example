# STECI UK Parish — copy to .env and run: php artisan key:generate
# Local: APP_URL=http://localhost:8000  |  Apache: APP_URL=http://localhost/your-folder/public

# --- Application ---
APP_NAME="STECI UK Parish"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
EXPOSE_EXCEPTION_DETAILS=false
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Database (SQLite) ---
DB_CONNECTION=sqlite
DB_DATABASE=storage/database/database.sqlite

# --- Optional: store data outside the project (paths resolve from project root) ---
# APP_STORAGE_PATH=../site_data/storage          # logs, cache, framework files
# PUBLIC_STORAGE_PATH=../site_data/pub_uploads   # public uploads (disk folder)
# PRIVATE_STORAGE_PATH=../site_data/private_uploads
# DB_DATABASE=../site_data/database/database.sqlite
# Then: mkdir folders, touch database file, php artisan storage:link
# PUBLIC_STORAGE_URL is the browser URL path only — never a folder path:
PUBLIC_STORAGE_URL=/storage

# --- Session, cache & queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Email is configured in admin → Site Settings → Email Setup (not in .env).

# --- Frontend ---
VITE_APP_NAME="${APP_NAME}"

# --- Security ---
FORCE_HTTPS=false
CSP_ENABLED=true
BLOCK_SUSPICIOUS_REQUESTS=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15
ADMIN_SESSION_LIFETIME=120
REQUIRE_MFA_SUPER_ADMIN=false
ALLOW_PAGE_CUSTOM_JS=false
LOG_EXCEPTION_MESSAGES=true
ADMIN_EMAIL=admin@steciuk.org
SECURITY_CONTACT=admin@steciuk.org
TRUSTED_PROXIES=

# --- Admin panel ---
ADMIN_PATH=admin
ADMIN_PANEL_NAME="${APP_NAME} Admin"
ADMIN_PANEL_SHORT_NAME="Parish Admin"

# --- Reference data (applied by php artisan migrate; keep off in production) ---
SEED_MODE=off
SEED_OVERWRITE_SETTINGS=false
SEED_OVERWRITE_USER_PASSWORDS=false
SEED_OVERWRITE_PAGES=true

# --- Production overrides (see README) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://steciuk.org
# FORCE_HTTPS=true
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# LOG_EXCEPTION_MESSAGES=false
# TRUSTED_PROXIES=*
# SEED_MODE=off
# APP_STORAGE_PATH=/var/lib/steciuk/storage
# PUBLIC_STORAGE_PATH=/var/lib/steciuk/pub_uploads
# PRIVATE_STORAGE_PATH=/var/lib/steciuk/private_uploads
# DB_DATABASE=/var/lib/steciuk/database/database.sqlite
