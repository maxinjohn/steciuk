# STECI UK Parish — copy to .env and run: php artisan key:generate
# Local: APP_URL=http://localhost:8000  |  Apache: APP_URL=http://localhost/your-folder/public

# --- Application ---
APP_NAME="STECI UK Parish"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
EXPOSE_EXCEPTION_DETAILS=false
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Database (SQLite + WAL) ---
# Recommended defaults for local dev. Verify with: php artisan site:doctor
# Do not run `php artisan test` while `php artisan serve` uses the same DB file.
DB_CONNECTION=sqlite
DB_DATABASE=storage/database/database.sqlite
DB_BUSY_TIMEOUT=10000
DB_JOURNAL_MODE=wal
DB_SYNCHRONOUS=normal
DB_WAL_AUTOCHECKPOINT=2000
DB_LOCK_RETRY_ATTEMPTS=3
DB_LOCK_RETRY_DELAY_MS=25
# DB_CACHE_SIZE=-128000
# DB_MMAP_SIZE=268435456
# After first deploy or repair: php artisan db:optimize-sqlite
# Scheduler runs db:optimize-sqlite daily/weekly/monthly automatically.

# --- Future-ready public UI (progressive enhancement) ---
# SITE_FUTURE_UI=true
# SITE_FUTURE_SPECULATION=false
# SITE_FUTURE_READING_PROGRESS=true

# --- Optional: store data outside the project (paths resolve from project root) ---
# APP_STORAGE_PATH=../site_data/storage
# PUBLIC_STORAGE_PATH=../site_data/pub_uploads
# PRIVATE_STORAGE_PATH=../site_data/private_uploads
# DB_DATABASE=../site_data/database/database.sqlite
# Then run: php artisan site:ensure-paths --link
# After changing any path above: php artisan config:clear && php artisan config:cache
# SITE_DATA_DIR_MODE=0775
PUBLIC_STORAGE_URL=/storage

# --- Session, cache & queue ---
# Keep sessions and cache off SQLite to reduce lock contention.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Email is configured in admin → Site Settings → Email Setup (not in .env).

# --- Frontend ---
VITE_APP_NAME="${APP_NAME}"

# --- Security ---
FORCE_HTTPS=false
CSP_ENABLED=true
BLOCK_SUSPICIOUS_REQUESTS=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15
# Admin inactivity timeout in minutes (fallback when not set in Admin → Security)
ADMIN_SESSION_LIFETIME=120
REQUIRE_MFA_SUPER_ADMIN=false
ALLOW_PAGE_CUSTOM_JS=false
LOG_EXCEPTION_MESSAGES=true
ADMIN_EMAIL=admin@steciuk.org
SECURITY_CONTACT=admin@steciuk.org
TRUSTED_PROXIES=

# Cloudflare Turnstile (registration CAPTCHA). Disable locally with TURNSTILE_ENABLED=false,
# or turn off "Registration security check" in Admin → Church & Faith → Site Defaults.
# If Cloudflare adds Trusted Types at the edge, keep CSP_ENABLED=true so the app can allow
# Turnstile's goog#html policy alongside Cloudflare's twKxV6 policy.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_ENABLED=false

# --- Admin panel ---
ADMIN_PATH=admin
ADMIN_PANEL_NAME="${APP_NAME} Admin"
ADMIN_PANEL_SHORT_NAME="Parish Admin"

# --- Reference data (applied by php artisan migrate; keep off in production) ---
SEED_MODE=off
SEED_OVERWRITE_SETTINGS=false
SEED_OVERWRITE_USER_PASSWORDS=false
SEED_OVERWRITE_PAGES=true

# --- Third-party (optional) ---
# GETADDRESS_API_KEY=

# --- Production overrides ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://steciuk.org
# FORCE_HTTPS=true
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# LOG_EXCEPTION_MESSAGES=false
# TRUSTED_PROXIES=*
# TURNSTILE_ENABLED=true
# SEED_MODE=off
# APP_STORAGE_PATH=/var/lib/steciuk/storage
# PUBLIC_STORAGE_PATH=/var/lib/steciuk/pub_uploads
# PRIVATE_STORAGE_PATH=/var/lib/steciuk/private_uploads
# DB_DATABASE=/var/lib/steciuk/database/database.sqlite
# DB_BUSY_TIMEOUT=10000
# DB_JOURNAL_MODE=wal
# DB_SYNCHRONOUS=normal
