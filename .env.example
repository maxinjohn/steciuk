# STECI UK Parish — copy to .env and run: php artisan key:generate
# Local: APP_URL=http://localhost:8000 (artisan serve)
# Apache: APP_URL=http://localhost/your-folder/public

APP_NAME="STECI UK Parish"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
EXPOSE_EXCEPTION_DETAILS=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

DB_CONNECTION=sqlite
DB_DATABASE=storage/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false

FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file
PUBLIC_STORAGE_URL=/storage

MAIL_MAILER=log
MAIL_FROM_ADDRESS="admin@steciuk.org"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

FORCE_HTTPS=false
CSP_ENABLED=true
BLOCK_SUSPICIOUS_REQUESTS=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15
ADMIN_SESSION_LIFETIME=120
REQUIRE_MFA_SUPER_ADMIN=false
ALLOW_PAGE_CUSTOM_JS=false
ADMIN_EMAIL=admin@steciuk.org
SECURITY_CONTACT=admin@steciuk.org

ADMIN_PATH=admin
ADMIN_PANEL_NAME="${APP_NAME} Admin"
ADMIN_PANEL_SHORT_NAME="Parish Admin"

SEED_MODE=bootstrap
SEED_OVERWRITE_SETTINGS=false
SEED_OVERWRITE_USER_PASSWORDS=false
SEED_OVERWRITE_PAGES=true

# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://steciuk.org,
# FORCE_HTTPS=true, SESSION_ENCRYPT=true, SESSION_SECURE_COOKIE=true,
# MAIL_MAILER=smtp, MAIL_HOST=, MAIL_PORT=587, MAIL_USERNAME=, MAIL_PASSWORD=,
# MAIL_ENCRYPTION=tls, TRUSTED_PROXIES=*, SEED_MODE=off
# See README for full deploy steps.
