# Optional deploy overrides — copy to scripts/deploy.env (gitignored) on the production server.
#
#   cp scripts/deploy.env.example scripts/deploy.env

# Git branch to deploy (merge dev → main locally, then deploy main on the server)
DEPLOY_BRANCH=main

# Git remote name
DEPLOY_GIT_REMOTE=origin

# Docker Compose command (use "docker compose" or full path if needed)
DEPLOY_COMPOSE="docker compose"

# Health check timeout (seconds)
DEPLOY_HEALTH_TIMEOUT=120

# Host port for smoke checks (should match NGINX_HTTP_PORT in .env)
# DEPLOY_HTTP_PORT=8080
